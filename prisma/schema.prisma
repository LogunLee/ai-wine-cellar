generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OAuthProvider {
  GOOGLE
}

enum WineType {
  RED
  WHITE
  ROSE
  SPARKLING
  SWEET
  FORTIFIED
  OTHER
}

enum CellarItemStatus {
  IN_CELLAR
  CONSUMED
  GIFTED
  LOST
}

enum NoteType {
  TASTING
  AI_ANSWER
  MANUAL
  PURCHASE
  OTHER
}

enum CellarMembershipRole {
  OWNER
  EDITOR
  VIEWER
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  login         String?  @unique
  displayName   String?  @map("display_name")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  credential        UserCredential?
  oauthIdentities   OAuthIdentity[]
  refreshTokens     RefreshToken[]
  wineCellars       WineCellar[]
  invitedMemberships CellarMembership[]   @relation("CellarMembershipInvitee")

  @@map("user")
}

model UserCredential {
  userId            String   @id @db.Uuid @map("user_id")
  passwordHash      String   @map("password_hash")
  passwordUpdatedAt DateTime @default(now()) @map("password_updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_credential")
}

model OAuthIdentity {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @db.Uuid @map("user_id")
  provider       OAuthProvider
  providerUserId String        @map("provider_user_id")
  providerEmail  String?       @map("provider_email")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_identity")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  tokenHash String   @map("token_hash")

  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  userAgent String? @map("user_agent")
  ip        String?

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("refresh_token")
}

model WineCellar {
  id        String   @id @default(uuid()) @db.Uuid
  ownerId   String   @db.Uuid @map("owner_id")
  name      String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner       User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  memberships CellarMembership[]
  items       CellarItem[]
  notes       Note[]

  @@index([ownerId])
  @@map("wine_cellar")
}

model CellarMembership {
  id         String             @id @default(uuid()) @db.Uuid
  cellarId   String             @db.Uuid @map("cellar_id")
  userId     String             @db.Uuid @map("user_id")
  role       CellarMembershipRole
  invitedAt  DateTime           @default(now()) @map("invited_at")
  acceptedAt DateTime?          @map("accepted_at")

  cellar WineCellar @relation(fields: [cellarId], references: [id], onDelete: Cascade)
  user   User       @relation("CellarMembershipInvitee", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cellarId, userId])
  @@index([userId])
  @@map("cellar_membership")
}

model Country {
  id   String @id @default(uuid()) @db.Uuid
  iso2 String @unique @db.Char(2)
  iso3 String? @unique @db.Char(3)
  name String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  wineSeries WineSeries[]

  @@map("country")
}

model GrapeVariety {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  nameMappings GrapeNameMapping[]

  @@map("grape_variety")
}

model GrapeNameMapping {
  id                  String   @id @default(uuid()) @db.Uuid
  grapeId             String   @db.Uuid @map("grape_id")
  inputText           String   @map("input_text")
  inputTextNormalized String   @map("input_text_normalized")

  locale  String?
  source  String?
  createdAt DateTime @default(now()) @map("created_at")

  grape GrapeVariety @relation(fields: [grapeId], references: [id], onDelete: Cascade)

  @@unique([inputTextNormalized])
  @@index([grapeId])
  @@map("grape_name_mapping")
}

model WineSeries {
  id        String   @id @default(uuid()) @db.Uuid
  producer  String
  name      String

  countryId  String  @db.Uuid @map("country_id")
  region     String?
  appellation String?

  wineType WineType @map("wine_type")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  country  Country      @relation(fields: [countryId], references: [id])
  vintages WineVintage[]

  @@index([countryId])
  @@index([wineType])
  @@map("wine_series")
}

model WineVintage {
  id        String  @id @default(uuid()) @db.Uuid
  seriesId  String  @db.Uuid @map("series_id")

  vintageYear Int?  @map("vintage_year")
  alcoholAbv  Decimal? @db.Decimal(4, 2) @map("alcohol_abv")
  volumeMl    Int?  @map("volume_ml")

  composition Json? @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  series     WineSeries  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  cellarItems CellarItem[]

  @@unique([seriesId, vintageYear])
  @@index([seriesId])
  @@map("wine_vintage")
}

model CellarItem {
  id            String  @id @default(uuid()) @db.Uuid
  cellarId      String  @db.Uuid @map("cellar_id")
  wineVintageId String  @db.Uuid @map("wine_vintage_id")

  quantity Int            @default(1)
  status   CellarItemStatus @default(IN_CELLAR)

  acquiredAt DateTime? @map("acquired_at")
  consumedAt DateTime? @map("consumed_at")

  purchasePrice Decimal? @db.Decimal(10, 2) @map("purchase_price")
  currency      String?  @db.VarChar(3)

  photoPath String? @map("photo_path")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  cellar      WineCellar  @relation(fields: [cellarId], references: [id], onDelete: Cascade)
  wineVintage WineVintage @relation(fields: [wineVintageId], references: [id])
  notes       Note[]

  @@index([cellarId, createdAt])
  @@index([cellarId, status])
  @@index([cellarId, wineVintageId])
  @@map("cellar_item")
}

model Note {
  id           String   @id @default(uuid()) @db.Uuid
  cellarId     String   @db.Uuid @map("cellar_id")
  cellarItemId String   @db.Uuid @map("cellar_item_id")

  noteType NoteType @map("note_type")
  title    String?
  text     String

  rating  Decimal? @db.Decimal(3, 1)
  tastedAt DateTime? @map("tasted_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  cellar     WineCellar @relation(fields: [cellarId], references: [id], onDelete: Cascade)
  cellarItem CellarItem @relation(fields: [cellarItemId], references: [id], onDelete: Cascade)

  @@index([cellarId, cellarItemId, createdAt])
  @@index([cellarId, noteType])
  @@map("note")
}
