generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AiModel {
  id           String         @id @default(uuid()) @db.Uuid
  name         String
  provider     String
  purpose      AiModelPurpose
  apiKey       String         @map("api_key")
  baseUrl      String?        @map("base_url")
  promptConfig Json?          @map("prompt_config")
  isDefault    Boolean        @default(false) @map("is_default")
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@index([purpose, isDefault])
  @@map("ai_model")
}

model User {
  id                 String             @id @default(uuid()) @db.Uuid
  email              String             @unique
  emailVerified      Boolean            @default(false) @map("email_verified")
  login              String?            @unique
  displayName        String?            @map("display_name")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  deletedAt          DateTime?          @map("deleted_at")
  avatarPath         String?            @map("avatar_path")
  invitedMemberships CellarMembership[] @relation("CellarMembershipInvitee")
  oauthIdentities    OAuthIdentity[]
  refreshTokens      RefreshToken[]
  credential         UserCredential?
  wineCellars        WineCellar[]
  deviceTokens       DeviceToken[]
  aiProviderKeys     UserProviderKey[]
  aiTaskSettings     UserTaskSetting[]
  aiTrialUsages      AiTrialUsage[]
  tastingNotes       TastingNote[]
  chatSessions       ChatSession[]

  @@map("user")
}

// ─── AI-настройки пользователя ────────────────────────────────────────────────

enum AiTaskScope {
  USER // настраивается пользователем, вызывается его действием
  SYSTEM // фоновые задачи приложения, всегда на ключах разработчика
}

/// Справочник провайдеров LLM. Наполняется разработчиком, для пользователей read-only.
model AiProvider {
  id              String            @id @default(uuid()) @db.Uuid
  code            String            @unique // gemini | mistral | openrouter
  name            String
  baseUrl         String            @map("base_url") // фиксированный URL, пользователь не вводит
  keyInstructions String            @map("key_instructions") // markdown: как выпустить ключ
  keyConsoleUrl   String            @map("key_console_url")
  freeTierNote    String?           @map("free_tier_note")
  sortOrder       Int               @default(0) @map("sort_order")
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  models          AiProviderModel[]
  userKeys        UserProviderKey[]

  @@map("ai_provider")
}

/// Модели внутри провайдера (справочник).
model AiProviderModel {
  id           String            @id @default(uuid()) @db.Uuid
  providerId   String            @map("provider_id") @db.Uuid
  code         String // gemini-2.0-flash
  name         String
  capabilities String[] // ["text"] | ["text","vision"]
  note         String?
  isActive     Boolean           @default(true) @map("is_active")
  provider     AiProvider        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  taskSettings UserTaskSetting[]

  @@unique([providerId, code])
  @@map("ai_provider_model")
}

/// Реестр AI-задач приложения. Наполняется разработчиком.
model AiTask {
  id                 String      @id @default(uuid()) @db.Uuid
  code               String      @unique // label_recognition | text_search | wine_research | ...
  name               String
  description        String?
  scope              AiTaskScope
  requiredCapability String      @map("required_capability") // text | vision
  defaultPrompt      String      @map("default_prompt")
  promptVersion      Int         @default(1) @map("prompt_version")
  promptEditable     Boolean     @default(false) @map("prompt_editable")
  /// false — задаче не нужна LLM-модель (например, «внешнее исследование»: только промпт-шаблон)
  requiresModel      Boolean     @default(true) @map("requires_model")
  recommendedModel   String?     @map("recommended_model") // "provider/model-code" для подсказки в UI
  trialLimit         Int         @default(10) @map("trial_limit")
  sortOrder          Int         @default(0) @map("sort_order")
  isActive           Boolean     @default(true) @map("is_active")

  @@map("ai_task")
}

/// Ключ пользователя к провайдеру: один на провайдера, шифрован AES-256-GCM, write-only.
model UserProviderKey {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  providerId String     @map("provider_id") @db.Uuid
  encKey     Bytes      @map("enc_key") // iv(12) + authTag(16) + ciphertext
  keyLast4   String     @map("key_last4")
  isValid    Boolean?   @map("is_valid")
  checkedAt  DateTime?  @map("checked_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId])
  @@map("user_provider_key")
}

/// Выбор модели (и опционально промпта) пользователем для конкретной задачи.
model UserTaskSetting {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  taskCode     String           @map("task_code")
  modelId      String?          @map("model_id") @db.Uuid // null допустим для задач с requiresModel=false
  customPrompt String?          @map("custom_prompt") // null = дефолтный промпт задачи
  updatedAt    DateTime         @updatedAt @map("updated_at")
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  model        AiProviderModel? @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([userId, taskCode])
  @@map("user_task_setting")
}

/// Счётчик пробных вызовов на ключах разработчика (per task).
model AiTrialUsage {
  userId   String @map("user_id") @db.Uuid
  taskCode String @map("task_code")
  used     Int    @default(0)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, taskCode])
  @@map("ai_trial_usage")
}

model DeviceToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  platform  String   @default("android")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_token")
}

model UserCredential {
  userId            String   @id @map("user_id") @db.Uuid
  passwordHash      String   @map("password_hash")
  passwordUpdatedAt DateTime @default(now()) @map("password_updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_credential")
}

model OAuthIdentity {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  provider       OAuthProvider
  providerUserId String        @map("provider_user_id")
  providerEmail  String?       @map("provider_email")
  createdAt      DateTime      @default(now()) @map("created_at")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_identity")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ip        String?
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("refresh_token")
}

model WineCellar {
  id          String             @id @default(uuid()) @db.Uuid
  ownerId     String             @map("owner_id") @db.Uuid
  name        String
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  items       CellarItem[]
  memberships CellarMembership[]
  notes       Note[]
  owner       User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("wine_cellar")
}

model CellarMembership {
  id         String               @id @default(uuid()) @db.Uuid
  cellarId   String               @map("cellar_id") @db.Uuid
  userId     String               @map("user_id") @db.Uuid
  role       CellarMembershipRole
  invitedAt  DateTime             @default(now()) @map("invited_at")
  acceptedAt DateTime?            @map("accepted_at")
  cellar     WineCellar           @relation(fields: [cellarId], references: [id], onDelete: Cascade)
  user       User                 @relation("CellarMembershipInvitee", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cellarId, userId])
  @@index([userId])
  @@map("cellar_membership")
}

model Country {
  id         String       @id @default(uuid()) @db.Uuid
  iso2       String       @unique @db.Char(2)
  iso3       String?      @unique @db.Char(3)
  name       String
  nameRu     String?      @map("name_ru")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  wineSeries WineSeries[]

  @@map("country")
}

model GrapeVariety {
  id           String             @id @default(uuid()) @db.Uuid
  name         String             @unique
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  nameMappings GrapeNameMapping[]

  @@map("grape_variety")
}

model GrapeNameMapping {
  id                  String       @id @default(uuid()) @db.Uuid
  grapeId             String       @map("grape_id") @db.Uuid
  inputText           String       @map("input_text")
  inputTextNormalized String       @unique @map("input_text_normalized")
  locale              String?
  source              String?
  createdAt           DateTime     @default(now()) @map("created_at")
  grape               GrapeVariety @relation(fields: [grapeId], references: [id], onDelete: Cascade)

  @@index([grapeId])
  @@map("grape_name_mapping")
}

model WineSeries {
  id          String        @id @default(uuid()) @db.Uuid
  producer    String
  name        String
  countryId   String        @map("country_id") @db.Uuid
  region      String?
  appellation String?
  wineType    WineType      @map("wine_type")
  vivinoUrl       String?   @map("vivino_url")
  wineSearcherUrl String?   @map("wine_searcher_url")
  criticScores    Json?     @map("critic_scores")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  country     Country       @relation(fields: [countryId], references: [id])
  vintages    WineVintage[]

  @@index([countryId])
  @@index([wineType])
  @@map("wine_series")
}

model WineVintage {
  id          String       @id @default(uuid()) @db.Uuid
  seriesId    String       @map("series_id") @db.Uuid
  vintageYear Int?         @map("vintage_year")
  alcoholAbv  Decimal?     @map("alcohol_abv") @db.Decimal(4, 2)
  volumeMl    Int?         @map("volume_ml")
  composition Json?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  cellarItems CellarItem[]
  series      WineSeries   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, vintageYear])
  @@index([seriesId])
  @@map("wine_vintage")
}

model CellarItem {
  id            String           @id @default(uuid()) @db.Uuid
  wineVintageId String           @map("wine_vintage_id") @db.Uuid
  quantity      Int              @default(1)
  status        CellarItemStatus @default(IN_CELLAR)
  acquiredAt    DateTime?        @map("acquired_at")
  consumedAt    DateTime?        @map("consumed_at")
  purchasePrice Decimal?         @map("purchase_price") @db.Decimal(10, 2)
  currency      String?          @db.VarChar(3)
  storageLocation String?        @map("storage_location")
  photoPath     String?          @map("photo_path")
  /// Free-text wine info the user pastes from external sources (can be very large).
  /// Primary signal for ai-search: chunked and embedded into wine_desc_chunk.
  userDescription   String?      @map("user_description") @db.Text
  /// Optional shorter description from the seller/source.
  sellerDescription String?      @map("seller_description") @db.Text
  /// Official producer tech-sheet text (grapes, vinification, aging). Chunked and
  /// embedded into wine_desc_chunk so queries like "Nebbiolo aged 36+ months in oak" match.
  producerDescription String?    @map("producer_description") @db.Text
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  deletedAt     DateTime?        @map("deleted_at")
  cellarId      String           @map("cellar_id") @db.Uuid
  cellar        WineCellar       @relation(fields: [cellarId], references: [id], onDelete: Cascade)
  wineVintage   WineVintage      @relation(fields: [wineVintageId], references: [id])
  notes         Note[]
  tastingNotes  TastingNote[]

  @@index([cellarId, createdAt])
  @@index([cellarId, status])
  @@index([cellarId, wineVintageId])
  @@map("cellar_item")
}

/// Личная дегустационная заметка пользователя о конкретном вине из его погреба.
/// «wine_id» из спецификации = cellarItemId (бутылка/карточка вина в погребе),
/// откуда берутся название, тип, страна, регион, сорта и фото для списка и фильтров.
/// Диалог с AI-сомелье (история чатов). Сообщения — в ChatMessage.
model ChatSession {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  title     String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId, updatedAt])
  @@map("chat_session")
}

/// Сообщение в диалоге с AI-сомелье. role: 'user'|'assistant'. mode: 'pogreb'|'consult'|'chat'.
/// picks — карточки вин из погреба (JSON), sources — цитаты из литературы (JSON).
model ChatMessage {
  id        String      @id @default(uuid()) @db.Uuid
  sessionId String      @map("session_id") @db.Uuid
  role      String
  mode      String?
  content   String      @db.Text
  picks     Json?
  sources   Json?
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_message")
}

model TastingNote {
  id                  String     @id @default(uuid()) @db.Uuid
  userId              String     @map("user_id") @db.Uuid
  /// Вино из погреба. Может быть null: заметка без вина (укажут позже) или вино введено вручную
  /// (поля manual* ниже). Кейс: вина нет в погребе и нет интернета.
  cellarItemId        String?    @map("cellar_item_id") @db.Uuid
  // Вручную введённое вино (когда cellarItemId = null).
  manualProducer      String?    @map("manual_producer")
  manualName          String?    @map("manual_name")
  manualVintageYear   Int?       @map("manual_vintage_year")
  manualCountry       String?    @map("manual_country")
  manualRegion        String?    @map("manual_region")
  manualWineType      WineType?  @map("manual_wine_type")
  vintage             Int?
  tastingDate         DateTime   @map("tasting_date") @db.Date
  /// Личная оценка 1.0–5.0 с шагом 0.1 (проверяется на уровне сервиса и CHECK-констрейнтом).
  rating              Decimal    @db.Decimal(2, 1)
  noteText            String?    @map("note_text") @db.Text
  vivinoNoteText      String?    @map("vivino_note_text") @db.Text
  vivinoNoteCreatedAt DateTime?  @map("vivino_note_created_at")
  vivinoNoteUpdatedAt DateTime?  @map("vivino_note_updated_at")
  place               String?
  price               Decimal?   @db.Decimal(10, 2)
  wouldBuyAgain       Boolean?   @map("would_buy_again")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cellarItem          CellarItem? @relation(fields: [cellarItemId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt, tastingDate, createdAt])
  @@index([cellarItemId])
  @@map("tasting_note")
}

model Note {
  id           String     @id @default(uuid()) @db.Uuid
  cellarItemId String     @map("cellar_item_id") @db.Uuid
  noteType     NoteType   @map("note_type")
  title        String?
  text         String
  rating       Decimal?   @db.Decimal(3, 1)
  tastedAt     DateTime?  @map("tasted_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")
  cellarId     String     @map("cellar_id") @db.Uuid
  cellar       WineCellar @relation(fields: [cellarId], references: [id], onDelete: Cascade)
  cellarItem   CellarItem @relation(fields: [cellarItemId], references: [id], onDelete: Cascade)

  @@index([cellarId, cellarItemId, createdAt])
  @@index([cellarId, noteType])
  @@map("note")
}

model Store {
  id                  String          @id @default(uuid()) @db.Uuid
  name                String
  code                String          @unique
  baseUrl             String          @map("base_url")
  active              Boolean         @default(true)
  parserType          StoreParserType @map("parser_type")
  scrapePeriodMinutes Int             @default(60) @map("scrape_period_minutes")
  currency            String          @default("RUB") @db.VarChar(3)
  country             String?         @db.VarChar(2)
  configJson          Json?           @map("config_json")
  lastSuccessAt       DateTime?       @map("last_success_at")
  lastErrorAt         DateTime?       @map("last_error_at")
  lastErrorMessage    String?         @map("last_error_message")
  deleted             Boolean         @default(false)
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  discountOffers      DiscountOffer[]
  rawOffers           RawOffer[]
  scrapeJobs          ScrapeJob[]
  wineCards           WineCard[]

  @@index([active, deleted])
  @@map("store")
}

/// Unified wine-region reference (a "справочник"). Raw region strings scraped from
/// different shops — in different languages, spellings and casing ("Cote de Nuits",
/// "кот де нюи") — are resolved (once, via LLM) to a single canonical region here.
/// Each distinct raw spelling becomes a RegionAlias pointing at one WineRegion.
model WineRegion {
  id            String        @id @default(uuid()) @db.Uuid
  canonicalName String        @map("canonical_name")
  canonicalKey  String        @unique @map("canonical_key")
  country       String?
  source        String        @default("llm")
  status        String        @default("resolved")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  aliases       RegionAlias[]
  offers        DiscountOffer[]

  @@map("wine_region")
}

/// Maps a normalized raw-region key (lowercased, transliterated, non-letters
/// stripped) to a canonical WineRegion. Acts as the resolution cache: each unique
/// raw spelling is resolved exactly once and looked up cheaply thereafter.
model RegionAlias {
  id        String     @id @default(uuid()) @db.Uuid
  regionKey String     @unique @map("region_key")
  rawValue  String     @map("raw_value")
  country   String?
  source    String     @default("llm")
  regionId  String     @map("region_id") @db.Uuid
  region    WineRegion @relation(fields: [regionId], references: [id])
  createdAt DateTime   @default(now()) @map("created_at")

  @@index([regionId])
  @@map("region_alias")
}

/// Persistent per-product characteristics cache. A wine of a given vintage never
/// changes its grapes/alcohol/appellation, so the product card is scraped ONCE
/// and reused on every subsequent run. Only prices (taken from the catalog list)
/// change between runs. Keyed by externalId when available, otherwise by URL.
model WineCard {
  id          String   @id @default(uuid()) @db.Uuid
  storeId     String   @map("store_id") @db.Uuid
  cardKey     String   @map("card_key")
  externalId  String?  @map("external_id")
  url         String
  grapes      String[] @default([])
  alcohol     Float?
  appellation String?
  country     String?
  region      String?
  color       String?
  description String?  @db.Text
  payloadJson Json?    @map("payload_json")
  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  store       Store    @relation(fields: [storeId], references: [id])

  @@unique([storeId, cardKey])
  @@index([storeId])
  @@map("wine_card")
}

model ScrapeJob {
  id                     String          @id @default(uuid()) @db.Uuid
  storeId                String          @map("store_id") @db.Uuid
  status                 ScrapeJobStatus
  startedAt              DateTime        @map("started_at")
  finishedAt             DateTime?       @map("finished_at")
  foundCount             Int             @default(0) @map("found_count")
  rawCreatedCount        Int             @default(0) @map("raw_created_count")
  rawUpdatedCount        Int             @default(0) @map("raw_updated_count")
  normalizedCreatedCount Int             @default(0) @map("normalized_created_count")
  normalizedUpdatedCount Int             @default(0) @map("normalized_updated_count")
  expiredCount           Int             @default(0) @map("expired_count")
  errorMessage           String?         @map("error_message")
  createdAt              DateTime        @default(now()) @map("created_at")
  rawOffers              RawOffer[]
  store                  Store           @relation(fields: [storeId], references: [id])

  @@index([storeId, createdAt])
  @@map("scrape_job")
}

model ScrapeCheckpoint {
  id              String    @id @default(uuid()) @db.Uuid
  storeId         String    @map("store_id") @db.Uuid
  category        String    @map("category")
  pageNum         Int       @default(1) @map("page_num")
  lastUrl         String?   @map("last_url")
  offersCollected Int       @default(0) @map("offers_collected")
  heartbeatAt     DateTime  @default(now()) @map("heartbeat_at")
  updatedAt       DateTime  @default(now()) @map("updated_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([storeId, category])
  @@index([storeId])
  @@map("scrape_checkpoint")
}

model RawOffer {
  id                 String         @id @default(uuid()) @db.Uuid
  storeId            String         @map("store_id") @db.Uuid
  scrapeJobId        String?        @map("scrape_job_id") @db.Uuid
  externalId         String?        @map("external_id")
  rawTitle           String         @map("raw_title")
  rawUrl             String         @map("raw_url")
  rawImageUrl        String?        @map("raw_image_url")
  rawCurrentPrice    Decimal?       @map("raw_current_price") @db.Decimal(10, 2)
  rawOldPrice        Decimal?       @map("raw_old_price") @db.Decimal(10, 2)
  rawDiscountPercent Int?           @map("raw_discount_percent")
  rawAvailability    String?        @map("raw_availability")
  rawPayloadJson     Json           @map("raw_payload_json")
  contentHash        String         @map("content_hash")
  collectedAt        DateTime       @default(now()) @map("collected_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  discountOffer      DiscountOffer?
  scrapeJob          ScrapeJob?     @relation(fields: [scrapeJobId], references: [id])
  store              Store          @relation(fields: [storeId], references: [id])

  @@unique([storeId, contentHash])
  @@index([storeId, collectedAt])
  @@index([scrapeJobId])
  @@map("raw_offer")
}

model DiscountOffer {
  id              String             @id @default(uuid()) @db.Uuid
  storeId         String             @map("store_id") @db.Uuid
  rawOfferId      String?            @unique @map("raw_offer_id") @db.Uuid
  sellerName      String             @map("seller_name")
  wineNameRaw     String             @map("wine_name_raw")
  producer        String?
  wineName        String?            @map("wine_name")
  fullName        String?            @map("full_name")
  vintage         String?
  country         String?
  region          String?
  regionKey       String?            @map("region_key")
  regionCanonical String?            @map("region_canonical")
  regionId        String?            @map("region_id") @db.Uuid
  originZone      String?            @map("origin_zone")
  appellation     String?
  sweetness       String?
  alcohol         Float?
  ageingVessel    String?            @map("ageing_vessel")
  storagePotential String?           @map("storage_potential")
  description     String?            @db.Text
  wineType        String?            @map("wine_type")
  volumeMl        Int?               @map("volume_ml")
  currentPrice    Decimal            @map("current_price") @db.Decimal(10, 2)
  oldPrice        Decimal?           @map("old_price") @db.Decimal(10, 2)
  discountPercent Int?               @map("discount_percent")
  discountAmount  Decimal?           @map("discount_amount") @db.Decimal(10, 2)
  currency        String             @default("RUB") @db.VarChar(3)
  url             String
  imageUrl        String?            @map("image_url")
  availability    String?
  grapes          String[]           @default([])
  grapeCount      Int                @default(0)   @map("grape_count")
  confidence      DiscountConfidence @default(medium)
  status          DiscountStatus     @default(active)
  firstSeenAt     DateTime           @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime           @default(now()) @map("last_seen_at")
  lastCheckedAt   DateTime           @default(now()) @map("last_checked_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  deleted         Boolean            @default(false)
  rawOffer        RawOffer?          @relation(fields: [rawOfferId], references: [id])
  store           Store              @relation(fields: [storeId], references: [id])
  regionRef       WineRegion?        @relation(fields: [regionId], references: [id])

  @@index([storeId, status, deleted])
  @@index([status, confidence])
  @@index([discountPercent])
  @@index([currentPrice])
  @@index([lastCheckedAt])
  @@index([wineType])
  @@index([country])
  @@index([grapeCount])
  @@index([regionKey])
  @@index([regionId])
  @@map("discount_offer")
}

