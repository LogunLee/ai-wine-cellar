{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true
  },
  "watchOptions": {
    "ignored": ["**/dist/**", "**/node_modules/**", "**/*.log", "**/temp/**", "**/uploads/**", "**/check-*.ts", "**/test-*.ts", "**/find-*.ts"]
  }
}
